# Flask Configuration
FLASK_APP=wsgi:app
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=dev-secret-key-change-in-production

# Application Configuration
APP_PORT=5000
APP_HOST=0.0.0.0

# MySQL Configuration
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=user
MYSQL_PASSWORD=password
MYSQL_DATABASE=databricks_iot
DATABASE_URL=mysql+pymysql://user:password@db:3306/databricks_iot

# Databricks Configuration
DATABRICKS_HOST=https://<workspace-url>.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/<warehouse-id>

# Authentication
AUTH_TYPE=azure
