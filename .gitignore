# すべてのファイルとディレクトリを除外
/*

# ドキュメント
!/docs/
!/docs/**
!/README.md
!/LICENSE
!/NOTICE
!/CLAUDE.md

# 開発環境設定
!/.devcontainer/
!/.devcontainer/**
!/.vscode/
!/.vscode/**

# アプリケーションコード（srcフォルダで開発）
!/src/
!/src/**

# DB初期化スクリプト
!/init/
!/init/**

# テストコード
!/tests/
!/tests/**

# 依存関係・設定ファイル
!/requirements.txt
!/wsgi.py
!/pytest.ini
!/Dockerfile

# 環境変数テンプレート（実際の.envは除外）
!/.env.example

# エディタ設定
!/.editorconfig

# Git設定
!.gitignore

# 機密情報・Databricks関連は除外
.env
*.key
*.pem
.databricks/
databricks.yml
credentials/

# データファイルは除外
users.json

# Python cache（src配下も含めて除外）
__pycache__/
*.py[cod]
docs/03-features/ldp-pipeline/gold_layer/review/review-report-20260401.md
.gitignore
docs/03-features/batch/scheduled-email-job/README.md
docs/03-features/batch/scheduled-email-job/job-specification.md
docs/03-features/ldp-pipeline/gold_layer/review/review-report.md
