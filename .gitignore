# すべてのファイルとディレクトリを除外
/*

# ドキュメント
!/docs/
!/docs/**
!/README.md
!/LICENSE
!/NOTICE
!/CLAUDE.md

# 開発環境設定
!/.devcontainer/
!/.devcontainer/**
!/.vscode/
!/.vscode/**

# アプリケーションコード（srcフォルダで開発）
!/src/
!/src/**

# 依存関係・設定ファイル
!/requirements.txt
!/Dockerfile

# 環境変数テンプレート（実際の.envは除外）
!/.env.example

# Git設定
!.gitignore

# 機密情報・Databricks関連は除外
.env
*.key
*.pem
.databricks/
databricks.yml
credentials/

# データファイルは除外
users.json
